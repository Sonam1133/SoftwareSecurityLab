<?php
session_start();

$conn = new mysqli("localhost", "root", "", "test");

if ($conn->connect_error) {
    die("Connection failed: " . $conn->connect_error);
}

$msg = "";
$mode = "register";
$color = "red";

// Handle mode switch
if (isset($_GET['mode']) && $_GET['mode'] == "login") {
    $mode = "login";
}

// Success message after register
if (isset($_GET['msg']) && $_GET['msg'] == "success") {
    $msg = "Registration Successful! Please login.";
    $color = "green";
}

// Logout
if (isset($_GET['logout'])) {
    session_destroy();
    header("Location: app.php?mode=login");
    exit();
}

// ================= REGISTER =================
if (isset($_POST['register'])) {

    $username = trim($_POST['username']);
    $password = trim($_POST['password']);

    $check = $conn->prepare("SELECT username FROM users WHERE username = ?");
    $check->bind_param("s", $username);
    $check->execute();
    $check->store_result();

    if ($check->num_rows > 0) {
        $msg = "Username already exists";
    } else {

        // HASH + SALT (bcrypt)
        $hashedPassword = password_hash($password, PASSWORD_DEFAULT);

        $stmt = $conn->prepare("INSERT INTO users (username, password) VALUES (?, ?)");
        $stmt->bind_param("ss", $username, $hashedPassword);

        if ($stmt->execute()) {
            header("Location: app.php?mode=login&msg=success");
            exit();
        } else {
            $msg = "Error during registration";
        }

        $stmt->close();
    }

    $check->close();
}

// ================= LOGIN =================
if (isset($_POST['login'])) {

    $mode = "login";

    $username = trim($_POST['username']);
    $password = trim($_POST['password']);

    $stmt = $conn->prepare("SELECT password FROM users WHERE username = ?");
    $stmt->bind_param("s", $username);
    $stmt->execute();

    $result = $stmt->get_result();

    if ($result->num_rows > 0) {
        $row = $result->fetch_assoc();

        // VERIFY HASH
        if (password_verify($password, $row['password'])) {
    $_SESSION['user'] = $username;

    //Redirect with success message
    header("Location: app.php?login=success");
    exit();
	} else {
            $msg = "login Successfully";
        }
    }
    $stmt->close();
}
